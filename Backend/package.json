{
  "name": "backend",
  "version": "1.0.0",
  "description": "backend for the project Gestion des horaires",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node scripts/free-dev-port.mjs && nodemon src/server.js",
    "sync:capacity": "node scripts/synchroniser-capacite-academique.mjs",
    "test": "node scripts/clean-coverage.mjs && node --disable-warning=ExperimentalWarning --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --runInBand",
    "test:coverage": "npm run test",
    "migrate": "echo Import Backend/Database/GDH5.sql manually. See Backend/Database/README.md"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "mysql2": "^3.18.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.18.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "brace-expansion": "^5.0.5"
  },
  "jest": {
    "testEnvironment": "node",
    "silent": true,
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setupTests.js"
    ],
    "coverageDirectory": "<rootDir>/coverage",
    "coverageReporters": [
      "text",
      "text-summary"
    ]
  }
}
